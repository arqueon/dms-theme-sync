{
  "$schema": "https://github.com/AvengeMedia/DankMaterialShell/raw/refs/heads/master/PLUGINS/plugin-schema.json",
  "id": "dmsThemeSync",
  "name": "DMS Theme Sync",
  "description": "Synchronize DMS fonts, sizes, icons, cursor and GTK/Qt application themes across Linux toolkits",
  "version": "0.5.0",
  "license": "GPL-3.0-or-later",
  "author": "arqueon",
  "icon": "palette",
  "type": "composite",
  "components": {
    "daemon": "./ThemeSyncService.qml",
    "widget": "./ThemeSyncWidget.qml"
  },
  "settings": "./ThemeSyncSettings.qml",
  "capabilities": ["appearance", "daemon", "ipc", "dankbar-widget"],
  "category": "appearance",
  "compositors": ["any"],
  "distro": ["any"],
  "requires": ["bash"],
  "requires_dms": ">=1.5.0",
  "permissions": ["process", "settings_read", "settings_write"]
}
